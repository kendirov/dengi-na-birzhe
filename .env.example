# Market data source mode
# mock     — учебные данные (default, честно labeled in UI)
# live     — MOEX ISS; на Vercel сервер может не достучаться — браузер подгрузит данные
# fallback — try MOEX; on failure → mock with «Резервные данные» + reason
MARKET_DATA_MODE=live

MOEX_BASE_URL=https://iss.moex.com
MOEX_HTTP_TIMEOUT_MS=12000

# Cache TTL for MOEX ISS responses (seconds)
# 900 = 15 минут
MARKET_DATA_REVALIDATE_SECONDS=900

# Optional: production URL for Open Graph metadata
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
